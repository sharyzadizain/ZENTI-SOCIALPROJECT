		"vue-router": "^4.6.4"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^7.2.0",
		"@nuxt/eslint": "^1.13.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "2.10.1",
		"@types/node": "^25.0.10",
		"eslint": "^9.39.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3"
